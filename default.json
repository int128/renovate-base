{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":automergeMinor",
    ":automergeDigest",
    ":assignAndReview(int128)"
  ],
  "platformAutomerge": false,
  "labels": [
    "renovate",
    "renovate/{{depName}}"
  ],
  "timezone": "Asia/Tokyo",
  "schedule": [
    "before 8am on Saturday",
    "before 8am on Sunday"
  ],
  "minimumReleaseAge": "7 days",
  "minimumReleaseAgeBehaviour": "timestamp-optional",
  "gitIgnoredAuthors": [
    "41898282+github-actions[bot]@users.noreply.github.com"
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": [
      "before 8am on Saturday",
      "before 8am on Sunday"
    ]
  },
  "packageRules": [
    {
      "description": "Auto-merge specific actions",
      "matchDepTypes": [
        "action"
      ],
      "matchPackageNames": [
        "actions/checkout",
        "docker/login-action",
        "docker/setup-buildx-action",
        "docker/setup-qemu-action",
        "docker/metadata-action",
        "docker/build-push-action"
      ],
      "automerge": true
    },
    {
      "description": "Auto-merge specific packages",
      "matchDatasources": [
        "npm"
      ],
      "matchPackageNames": [
        "@actions/*",
        "@graphql-codegen/*",
        "@vitejs/*",
        "typescript"
      ]
    },
    {
      "description": "Immediately update my packages",
      "matchDatasources": [
        "github-releases",
        "github-tags"
      ],
      "matchPackageNames": [
        "int128/*"
      ],
      "minimumReleaseAge": "0"
    }
  ]
}